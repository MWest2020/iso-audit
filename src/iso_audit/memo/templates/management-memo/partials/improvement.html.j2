{#- Eén verbeterpunt (variabele `imp`) -#}
<h2>Verbeterpunt — {{ imp.title }}</h2>

<h4>Norm</h4>
{% for c in imp.citations %}
<p class="norm-ref">{{ c.standard }} §{{ c.clause }} — {{ c.title }}</p>
<div class="norm-quote">"{{ c.text }}"</div>
{% endfor %}

<h4>Waar de praktijk afwijkt</h4>
<div>{{ imp.deviation | safe }}</div>
{% if imp.bronnen %}
<p class="reasoning"><em>Brondocumenten:</em></p>
<ul class="reasoning">
{% for b in imp.bronnen %}
<li>[{{ b.herkomst }}] {% if b.url %}<a href="{{ b.url }}">{{ b.doc_naam or b.doc_id or b.herkomst }}</a>{% else %}{{ b.doc_naam or b.doc_id }}{% endif %}{% if b.beschrijving %} — {{ b.beschrijving }}{% endif %}</li>
{% endfor %}
</ul>
{% endif %}

<h4>Waarom verbeterpunt en geen NC?</h4>
<div>{{ imp.classification_rationale | safe }}</div>

{% if imp.suggestion %}
<div class="recommendation"><strong>Aanbeveling:</strong> {{ imp.suggestion | safe }}</div>
{% endif %}
